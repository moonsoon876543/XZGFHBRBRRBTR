<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>My Portfolio</title>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;600&display=swap" rel="stylesheet">
  <style>
    /* Basic Reset */
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Poppins', sans-serif;
      line-height: 1.6;
      background: #f8f9fa;
      color: #333;
    }

    header {
      background: #222;
      color: #fff;
      padding: 20px 0;
    }

    nav {
      width: 90%;
      margin: auto;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    nav .logo {
      font-size: 24px;
      font-weight: 600;
    }

    nav ul {
      list-style: none;
      display: flex;
      gap: 20px;
    }

    nav ul li a {
      color: #fff;
      text-decoration: none;
      transition: color 0.3s;
    }

    nav ul li a:hover {
      color: #00bcd4;
    }

    .hero {
      background: linear-gradient(to right, #00bcd4, #009688);
      color: white;
      padding: 100px 20px;
      text-align: center;
    }

    .hero h2 {
      font-size: 36px;
      margin-bottom: 10px;
    }

    .hero .btn {
      display: inline-block;
      margin-top: 20px;
      padding: 10px 25px;
      background: white;
      color: #009688;
      border-radius: 5px;
      text-decoration: none;
      font-weight: bold;
    }

    .section {
      padding: 60px 20px;
      max-width: 1000px;
      margin: auto;
      text-align: center;
    }

    .project-grid {
      display: flex;
      flex-wrap: wrap;
      gap: 20px;
      justify-content: center;
      margin-top: 30px;
    }

    .project-card {
      background: white;
      border: 1px solid #ddd;
      padding: 20px;
      width: 250px;
      border-radius: 8px;
      box-shadow: 2px 2px 10px rgba(0,0,0,0.05);
    }

    form {
      display: flex;
      flex-direction: column;
      gap: 15px;
      max-width: 500px;
      margin: auto;
    }

    form input, form textarea {
      padding: 10px;
      border: 1px solid #ccc;
      border-radius: 5px;
    }

    form .btn {
      background: #009688;
      color: white;
      border: none;
      cursor: pointer;
    }

    form .btn:hover {
      background: #00796b;
    }

    footer {
      text-align: center;
      padding: 20px;
      background: #222;
      color: white;
      margin-top: 40px;
    }

    /* Responsive */
    @media (max-width: 768px) {
      nav ul {
        flex-direction: column;
        gap: 10px;
      }

      .project-grid {
        flex-direction: column;
        align-items: center;
      }
    }
  </style>
</head>
<body>

  <header>
    <nav>
      <h1 class="logo">MyPortfolio</h1>
      <ul>
        <li><a href="#home">Home</a></li>
        <li><a href="#about">About Me</a></li>
        <li><a href="#projects">Projects</a></li>
        <li><a href="#blog">Blog</a></li>
        <li><a href="#contact">Contact</a></li>
        <li><a href="resume.pdf" download>Resume</a></li>
      </ul>
    </nav>
  </header>

  <section id="home" class="hero">
    <div class="hero-content">
      <h2>Hello, I'm Ali Haider</h2>
      <p>A passionate Web Developer</p>
      <a href="#projects" class="btn">See My Work</a>
    </div>
  </section>

  <section id="about" class="section">
    <h2>About Me</h2>
    <p>I am a self-taught developer learning HTML, CSS, and Python. I love creating beautiful websites and building backend logic.</p>
  </section>

  <section id="projects" class="section">
    <h2>Projects</h2>
    <div class="project-grid">
      <div class="project-card">
        <h3>Project One</h3>
        <p>Short description of your project.</p>
      </div>
      <div class="project-card">
        <h3>Project Two</h3>
        <p>Another cool project you’ve built.</p>
      </div>
    </div>
  </section>

  <section id="blog" class="section">
    <h2>Blog</h2>
    <p>Coming Soon...</p>
  </section>

  <!-- ✅ Final Functional Contact Form -->
  <section id="contact" class="section">
    <h2>Contact Me</h2>
    <form action="https://formspree.io/f/mpwrgeda" method="POST">
      <input type="text" name="name" placeholder="Your Name" required />
      <input type="email" name="email" placeholder="Your Email" required />
      <textarea name="message" placeholder="Your Message" required></textarea>
      <button type="submit" class="btn">Send</button>
    </form>
  </section>

  <footer>
    <p>&copy; 2025 Ali Haider. All rights reserved.</p>
  </footer>

</body>
</html>
